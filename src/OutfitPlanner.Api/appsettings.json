{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=OutfitPlannerDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "Key": "[YOUR_JWT_SECRET_KEY]",
    "Issuer": "OutfitPlanner",
    "Audience": "OutfitPlanner-API",
    "DurationInMinutes": 60,
    "RefreshTokenDurationInDays": 7
  },
  "WeatherApi": {
    "ApiKey": "[YOUR_WEATHER_API_KEY]",
    "BaseUrl": "https://api.openweathermap.org/data/2.5",
    "Units": "metric",
    "TimeoutSeconds": 30
  },
  "BackgroundRemoval": {
    "Provider": "RemoveBg",
    "ApiKey": "[YOUR_REMOVEBG_API_KEY]",
    "Enabled": true
  },
  "OutfitImageCache": {
    "EnablePreGeneration": true
  }
}


