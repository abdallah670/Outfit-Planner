{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=OutfitPlannerDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "JwtSettings": {
    "Key": "[YOUR_JWT_SECRET_KEY]",
    "Issuer": "OutfitPlanner",
    "Audience": "OutfitPlanner-API",
    "DurationInMinutes": 60,
    "RefreshTokenDurationInDays": 7
  },
  "WeatherApi": {
    "ApiKey": "[YOUR_WEATHER_API_KEY]",
    "BaseUrl": "https://api.openweathermap.org/data/2.5",
    "Units": "metric",
    "TimeoutSeconds": 30
  },
  "BackgroundRemoval": {
    "Provider": "RemoveBg",
    "ApiKey": "[YOUR_REMOVEBG_API_KEY]",
    "Enabled": true
  },
  "OutfitImageCache": {
    "EnablePreGeneration": true
  },
  "AI": {
    "ApiKey": "[YOUR_GCP_API_KEY]"
  },
  "Authentication": {
    "Google": {
      "ClientId": "[YOUR_GOOGLE_CLIENT_ID]",
      "ClientSecret": "[YOUR_GOOGLE_CLIENT_SECRET]"
    },
    "Facebook": {
      "AppId": "[YOUR_FACEBOOK_APP_ID]",
      "AppSecret": "[YOUR_FACEBOOK_APP_SECRET]"
    }
  },
  "EmailSettings": {
    "From": "outfit-planner@example.com",
    "DisplayName": "Outfit Planner",
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "EnableSsl": true
  },
  "BackupSettings": {
    "BackupDirectory": "Backups",
    "DefaultRetentionDays": 30,
    "MaxBackupSizeMB": 500,
    "CompressionEnabled": true,
    "ScheduledBackups": {
      "Daily": "0 2 * * *",
      "Weekly": "0 3 * * 0",
      "Monthly": "0 4 1 * *"
    }
  },
  "CacheSettings": {
    "DefaultExpirationMinutes": 30,
    "MaxCacheSizeMB": 100,
    "EnableSlidingExpiration": true,
    "SlidingExpirationMinutes": 15
  },
  "MaintenanceSettings": {
    "DefaultMessage": "System is currently under maintenance. Please try again later.",
    "AllowedIpAddresses": ["127.0.0.1", "::1"],
    "BypassMaintenanceForAdmins": true
  },
  "ServiceManagementSettings": {
    "HealthCheckIntervalSeconds": 60,
    "LogRetentionDays": 7,
    "MetricsRetentionHours": 24,
    "ServiceRestartTimeoutSeconds": 30,
    "EnableAutoRestart": false
  },
  "UserActivitySettings": {
    "ActivityRetentionDays": 90,
    "SessionTimeoutMinutes": 30,
    "EnableDetailedTracking": true,
    "TrackPageViews": true,
    "TrackUserActions": true
  }
}


